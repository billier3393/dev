{
  "model": "claude-sonnet-4-5",
  "toolSearch": "auto",
  "env": {
    "CLAUDE_TEAM_ENABLED": "0"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify-complete.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/task-gate.sh"
          }
        ]
      }
    ]
  }
}
