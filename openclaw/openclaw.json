          "claude-haiku-4.5": {
            "id": "claude-haiku-4-5-20251001",
            "inputPrice": 1.00,
            "outputPrice": 5.00,
            "batchInputPrice": 0.50,
            "batchOutputPrice": 2.50,
            "contextWindow": 200000,
            "maxOutput": 8192
