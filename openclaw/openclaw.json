  "messaging": {
    "enabled": true,
    "directory": "shared/messages",
    "format": "jsonl",
    "maxMessageSize": 4096,
    "retentionDays": 7,
    "channels": {
      "broadcast": { "type": "pubsub", "subscribers": "all" },
      "c-suite": { "type": "group", "members": ["ceo","cto","coo"] },
      "tech": { "type": "group", "members": ["cto","dev-lead","testing-lead","security-lead"] },
      "ops": { "type": "group", "members": ["coo","docs-lead","data-lead","creative-lead","optim-lead"] }
    }
  },
  "locking": {
    "enabled": true,
    "directory": "shared/locks",
    "timeoutSeconds": 300,
    "staleLockCleanupMinutes": 10,
    "maxRetries": 3
  },
  "batchApi": {
    "enabled": true,
    "provider": "anthropic",
    "collectorIntervalMinutes": 15,
    "maxBatchSize": 100,
    "maxWaitMinutes": 30,
    "queueDirectory": "shared/batch_queue",
    "resultsDirectory": "shared/batch_results",
    "eligibleTasks": ["bulk-analysis","report-generation","code-review","data-processing","ocr-batch"]
  },
  "workspace": {
    "shared": {
      "directory": "shared",
      "subdirs": ["messages","locks","batch_queue","batch_results","handoffs","artifacts"]
    },
    "personalDirs": {
      "enabled": true,
      "baseDir": "agents",
      "structure": ["inbox","outbox","workspace","scratch"]
    }
  },
  "bindings": [
    { "agentId": "ceo", "match": { "channel": "telegram" } }
  ],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "userCommandPreservation": {
      "enabled": true,
      "policy": "never-compress-user-commands",
      "logOriginal": true,
      "storePath": "memory/user_commands.jsonl"
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": { "enabled": true },
        "bootstrap-extra-files": { "enabled": true },
        "command-logger": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "streamMode": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_TOKEN}"
    },
    "tailscale": { "mode": "off", "resetOnExit": false },
    "nodes": {
      "denyCommands": [
        "camera.snap","camera.clip","screen.record",
        "calendar.add","contacts.add","reminders.add"
      ]
    }
  },
  "security": {
    "emailValidation": {
      "enabled": true,
      "requireUserApproval": true,
      "maxRecipientsPerEmail": 5,
      "blockedDomains": [],
      "confirmationPrompt": "이메일 전송을 승인하시겠습니까? (승인/반려)"
    },
    "memoryEncryption": {
      "enabled": true,
      "algorithm": "AES-256-GCM",
      "keyEnvVar": "MEMORY_ENCRYPTION_KEY",
      "encryptedPaths": ["memory/*.json","memory/*.jsonl","agents/*/inbox/*","agents/*/outbox/*"]
    },
    "injectionDefense": {
      "enabled": true,
      "patterns": ["시스템:","SYSTEM:","ignore previous","새로운 지시","forget .* instructions","you are now","pretend to be","act as if"],
      "action": "warn-and-ignore",
      "logFile": "security/injection_log.jsonl"
    }
  },
  "plugins": {
    "entries": {
      "telegram": { "enabled": true }
    }
  },
  "skills": {
    "load": { "watch": true }
  }
}
