          "kimi-k2.5": {
            "id": "kimi-k2.5",
            "inputPrice": 0.60,
            "outputPrice": 3.00,
            "contextWindow": 131072,
            "maxOutput": 8192
          }
        }
      }
    }
  },
  "budget": {
    "monthly": {
      "limitUSD": 50.00,
      "warningThresholdPercent": 70,
      "criticalThresholdPercent": 90,
      "trackingFile": "memory/budget_tracker.json",
      "resetDay": 1
    },
    "daily": {
      "softLimitUSD": 2.00,
      "hardLimitUSD": 5.00
